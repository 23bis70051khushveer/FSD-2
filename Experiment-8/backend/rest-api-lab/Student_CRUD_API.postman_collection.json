{
    "info": {
        "_postman_id": "exp8-student-crud-api",
        "name": "Experiment 8 - Student CRUD API",
        "description": "RESTful CRUD APIs for Student Management using Flask.\n\nEndpoints:\n- Health Check\n- Create Student (POST)\n- Get All Students (GET)\n- Get Student by ID (GET)\n- Update Student (PUT)\n- Delete Student (DELETE)\n\nAuthor: Khushveer Singh (23BIS70051)",
        "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
    },
    "variable": [
        {
            "key": "base_url",
            "value": "http://localhost:5000",
            "type": "string"
        }
    ],
    "item": [
        {
            "name": "Health Check",
            "request": {
                "method": "GET",
                "header": [],
                "url": {
                    "raw": "{{base_url}}/",
                    "host": [
                        "{{base_url}}"
                    ],
                    "path": [
                        ""
                    ]
                },
                "description": "Check if the backend server is running."
            },
            "response": []
        },
        {
            "name": "Create Student",
            "request": {
                "method": "POST",
                "header": [
                    {
                        "key": "Content-Type",
                        "value": "application/json"
                    }
                ],
                "body": {
                    "mode": "raw",
                    "raw": "{\n    \"name\": \"Khushveer Singh\",\n    \"age\": 21\n}"
                },
                "url": {
                    "raw": "{{base_url}}/students",
                    "host": [
                        "{{base_url}}"
                    ],
                    "path": [
                        "students"
                    ]
                },
                "description": "Create a new student. Requires 'name' (required) and 'age' (optional) in the JSON body."
            },
            "response": []
        },
        {
            "name": "Create Student 2",
            "request": {
                "method": "POST",
                "header": [
                    {
                        "key": "Content-Type",
                        "value": "application/json"
                    }
                ],
                "body": {
                    "mode": "raw",
                    "raw": "{\n    \"name\": \"Rahul Sharma\",\n    \"age\": 22\n}"
                },
                "url": {
                    "raw": "{{base_url}}/students",
                    "host": [
                        "{{base_url}}"
                    ],
                    "path": [
                        "students"
                    ]
                },
                "description": "Create a second student to test multiple entries."
            },
            "response": []
        },
        {
            "name": "Get All Students",
            "request": {
                "method": "GET",
                "header": [],
                "url": {
                    "raw": "{{base_url}}/students",
                    "host": [
                        "{{base_url}}"
                    ],
                    "path": [
                        "students"
                    ]
                },
                "description": "Retrieve a list of all students."
            },
            "response": []

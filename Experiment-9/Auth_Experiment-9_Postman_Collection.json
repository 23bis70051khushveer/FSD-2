{
    "info": {
        "_postman_id": "ab704044-84fb-4b95-aadc-efee84d0b166",
        "name": "Auth Experiment-9 Collection",
        "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
    },
    "item": [
        {
            "name": "1. Basic Authentication Token",
            "request": {
                "auth": {
                    "type": "basic",
                    "basic": [
                        {
                            "key": "password",
                            "value": "admin123",
                            "type": "string"
                        },
                        {
                            "key": "username",
                            "value": "admin",
                            "type": "string"
                        }
                    ]
                },
                "method": "GET",
                "header": [],
                "url": {
                    "raw": "http://localhost:5000/basic-protected",
                    "protocol": "http",
                    "host": [
                        "localhost"
                    ],
                    "port": "5000",
                    "path": [
                        "basic-protected"
                    ]
                }
            },
            "response": []
        },
        {
            "name": "2A. Simple Token - Login",
            "event": [
                {
                    "listen": "test",
                    "script": {
                        "exec": [
                            "var jsonData = JSON.parse(responseBody);",
                            "postman.setEnvironmentVariable(\"simple_token\", jsonData.token);"
                        ],
                        "type": "text/javascript"
                    }
                }
            ],
            "request": {
                "method": "POST",
                "header": [
                    {
                        "key": "Content-Type",
                        "value": "application/json",
                        "type": "text"
                    }
                ],
                "body": {
                    "mode": "raw",
                    "raw": "{\n    \"username\": \"admin\",\n    \"password\": \"admin123\"\n}"
                },
                "url": {
                    "raw": "http://localhost:5000/token-login",
                    "protocol": "http",
                    "host": [
                        "localhost"
                    ],
                    "port": "5000",
                    "path": [
                        "token-login"
                    ]
                }
            },
            "response": []
        },
        {
            "name": "2B. Simple Token - Protected Route",
            "request": {
                "method": "GET",
                "header": [
                    {
                        "key": "x-auth-token",
                        "value": "{{simple_token}}",
                        "type": "text"
                    }
                ],
                "url": {
                    "raw": "http://localhost:5000/token-protected",
                    "protocol": "http",
                    "host": [
                        "localhost"
                    ],
                    "port": "5000",
                    "path": [
                        "token-protected"
                    ]
                }
            },
            "response": []
        },
        {
            "name": "3A. JWT - Login",
            "event": [
                {
                    "listen": "test",
                    "script": {
                        "exec": [
                            "var jsonData = JSON.parse(responseBody);",
                            "postman.setEnvironmentVariable(\"jwt_token\", jsonData.access_token);"
                        ],
                        "type": "text/javascript"
                    }
                }
            ],
            "request": {
                "method": "POST",
                "header": [
                    {
                        "key": "Content-Type",
                        "value": "application/json",
                        "type": "text"
                    }
                ],
                "body": {
                    "mode": "raw",
                    "raw": "{\n    \"username\": \"admin\",\n    \"password\": \"admin123\"\n}"
                },
                "url": {
                    "raw": "http://localhost:5000/jwt-login",
                    "protocol": "http",
                    "host": [
                        "localhost"
                    ],
                    "port": "5000",
                    "path": [
                        "jwt-login"
                    ]
                }
            },
            "response": []
        },
        {
            "name": "3B. JWT - Protected Route",
            "request": {
                "auth": {
                    "type": "bearer",
                    "bearer": [
                        {
                            "key": "token",
                            "value": "{{jwt_token}}",
                            "type": "string"
                        }
                    ]
                },
                "method": "GET",
                "header": [],
                "url": {
                    "raw": "http://localhost:5000/jwt-protected",
                    "protocol": "http",
                    "host": [
                        "localhost"
                    ],
                    "port": "5000",
                    "path": [
                        "jwt-protected"
                    ]
                }
            },
            "response": []
        }
    ]
}